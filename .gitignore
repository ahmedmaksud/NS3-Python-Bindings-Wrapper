# Python Bindings .gitignore
# Author: Ahmed Maksud <ahmed.maksud@email.ucr.edu>

# Build artifacts
*.o
*.so
*.pyc
__pycache__/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Log files
*.log
*.csv
pb-core-log.csv
pb-wrapper-demo-log.csv

# PCAP files
*.pcap
*-pcap/

# CMake generated files
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# Backup files
*.bak
*.backup

# OS specific
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
