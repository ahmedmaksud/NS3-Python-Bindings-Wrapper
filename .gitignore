# Python Bindings .gitignore
# Author: Ahmed Maksud <amaks002@ucr.edu>

# Build artifacts
*.o
*.so
*.pyc
__pycache__/
*.egg-info/
dist/
build/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Log files
*.log
*.csv
pb-core-log.csv
pb-wrapper-demo-log.csv

# PCAP files
*.pcap
*-pcap/

# CMake generated files
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# NS-3 build outputs
*.exe
*.dll
*.dylib

# Backup files
*.bak
*.backup
*~

# OS specific
.DS_Store
Thumbs.db

# Temporary files
*.tmp
*.temp
